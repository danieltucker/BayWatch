# DriveMap — Environment Configuration
# Copy to .env and fill in values before running.

# Port to expose the web UI on
APP_PORT=8585

# Database — do not change unless using an external database
DATABASE_URL=sqlite:////app/data/drivemap.db

# Telegram notifications (configure via Settings UI or here)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Background scan interval in minutes (0 to disable)
SCAN_INTERVAL_MINUTES=60

# Drive temperature alert threshold in Celsius
TEMP_ALERT_THRESHOLD_C=55

# Days before warranty expiry to start warning
WARRANTY_WARNING_DAYS=90

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
